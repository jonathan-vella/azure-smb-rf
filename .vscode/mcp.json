{
  "servers": {
    "azure-pricing": {
      "type": "stdio",
      "command": "${workspaceFolder}/mcp/azure-pricing-mcp/.venv/bin/python",
      "args": [
        "-m",
        "azure_pricing_mcp"
      ],
      "cwd": "${workspaceFolder}/mcp/azure-pricing-mcp/src"
    },
    "github": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/"
    },
    "drawio": {
      "type": "stdio",
      "command": "deno",
      "args": [
        "run",
        "-P",
        "--no-check",
        "--cached-only",
        "${workspaceFolder}/mcp/drawio-mcp-server/src/index.ts"
      ]
    }
  }
}
