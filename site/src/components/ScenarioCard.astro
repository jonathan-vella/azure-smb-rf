---
interface Props {
  title: string;
  cost: string;
  href: string;
  thumb?: string;
  alt?: string;
}
const { title, cost, href, thumb, alt = "" } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const thumbUrl = thumb ? `${base}${thumb}` : null;
---

<a class="scenario-card" href={href}>
  {thumbUrl && (
    <div class="sc-thumb">
      <img src={thumbUrl} alt={alt} loading="lazy" decoding="async" />
    </div>
  )}
  <div class="sc-body">
    <h3 class="sc-title">{title}</h3>
    <span class="sc-cost">{cost}</span>
    <p class="sc-desc"><slot /></p>
  </div>
</a>
