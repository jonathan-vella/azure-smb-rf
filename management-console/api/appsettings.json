{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AzureAd": {
    "Instance": "https://login.microsoftonline.com/",
    "TenantId": "${AZURE_TENANT_ID}",
    "ClientId": "${API_CLIENT_ID}",
    "Audience": "${API_AUDIENCE}"
  },
  "Spa": {
    "Origin": "${SPA_ORIGIN:-http://localhost:5173}"
  },
  "Lighthouse": {
    "OfferName": "smb-ready-foundation-partner",
    "OfferDescription": "Partner management console for SMB Ready Foundation deployments"
  },
  "Prerequisites": {
    "TemplateSource": {
      "Repo": "jonathan-vella/azure-smb-rf",
      "Tag": "main",
      "TemplatePath": "infra/bicep/smb-ready-foundation/deploy-mg.bicep",
      "PolicyTemplatePath": "infra/bicep/smb-ready-foundation/modules/policy-assignments-mg-initiative.bicep",
      "CacheMinutes": 60
    }
  },
  "AllowedHosts": "*"
}
